generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String             @id @default(cuid())
  email     String             @unique
  name      String?
  watchlist WatchlistItem[]
  history   WatchHistoryItem[]
}

model WatchlistItem {
  id         String   @id @default(cuid())
  userId     String
  mediaId    String // TMDB / Jikan / MangaDex id
  mediaType  String // 'movie' | 'tv' | 'anime' | 'manga'
  title      String
  posterPath String?
  addedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, mediaType])
}

model WatchHistoryItem {
  id         String   @id @default(cuid())
  userId     String
  mediaId    String
  mediaType  String
  title      String
  posterPath String?
  progress   Float // 0-1, fraction watched
  watchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
}
